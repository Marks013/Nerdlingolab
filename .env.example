NODE_ENV="development"
APP_URL="http://localhost:3000"

POSTGRES_DB="nerdlingolab"
POSTGRES_USER="nerdlingolab"
POSTGRES_DATA_DIR=/srv/nerdlingolab/postgres-data
POSTGRES_PASSWORD="replace-with-a-strong-password"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql://nerdlingolab:replace-with-a-strong-password@localhost:5432/nerdlingolab?schema=public"

AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_TRUST_HOST="true"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="replace-with-openssl-rand-base64-32"
DATA_ENCRYPTION_KEY="replace-with-openssl-rand-base64-32"

SUPERADMIN_NAME="NerdLingoLab Admin"
SUPERADMIN_EMAIL="admin@nerdlingolab.com"
SUPERADMIN_PASSWORD="replace-with-a-strong-admin-password"

MINIO_ROOT_USER="nerdlingolab"
MINIO_DATA_DIR=/srv/nerdlingolab/minio-data
MINIO_ROOT_PASSWORD="replace-with-a-strong-minio-password"
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_BUCKET="product-images"
S3_ACCESS_KEY_ID="nerdlingolab"
S3_SECRET_ACCESS_KEY="replace-with-a-strong-minio-password"

# Hosts HTTPS confiaveis para imagens remotas do catalogo/tema.
# Inclui por padrao: cdn.shopify.com, cdn.shopifycdn.net, nerdlingolab.com, www.nerdlingolab.com
NEXT_IMAGE_REMOTE_HOSTS=""

MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=""
MERCADO_PAGO_WEBHOOK_SECRET=""
MERCADO_PAGO_WEBHOOK_URL=""
MERCADO_PAGO_RETURN_URL_BASE=""
MERCADO_ENVIOS_ACCESS_TOKEN=""
CHECKOUT_PENDING_PAYMENT_TTL_HOURS="24"

MELHOR_ENVIO_ACCESS_TOKEN=""
MELHOR_ENVIO_BASE_URL="https://sandbox.melhorenvio.com.br"
MELHOR_ENVIO_FROM_POSTAL_CODE=""
MELHOR_ENVIO_USER_AGENT="NerdLingoLab (nerdlingolab@gmail.com)"
MELHOR_ENVIO_SERVICE_IDS=""

DROPSHIPPING_CHECKOUT_STRICT="false"

RESEND_API_KEY=""
EMAIL_FROM="NerdLingoLab <no-reply@nerdlingolab.com>"
SUPPORT_EMAIL="nerdlingolab@gmail.com"

MAINTENANCE_MODE="false"
MAINTENANCE_BYPASS_TOKEN=""
MAINTENANCE_MESSAGE=""
MAINTENANCE_RETRY_AFTER_SECONDS="900"

SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
SENTRY_RELEASE=""
NEXT_PUBLIC_SENTRY_RELEASE=""
SENTRY_ENABLE_LOGS="false"
NEXT_PUBLIC_SENTRY_ENABLE_LOGS="false"
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
SENTRY_PERSONAL_AUTH_TOKEN=""
SENTRY_CLIENT_ID=""
SENTRY_CLIENT_SECRET=""
SENTRY_SECURITY_TOKEN=""
SENTRY_AUTH_URL="https://sentry.io/oauth/authorize/"
SENTRY_TOKEN_URL="https://sentry.io/oauth/token/"
SENTRY_REGION_URL="https://us.sentry.io"

# Backups criptografados via GitHub Releases
BACKUP_CRON_SCHEDULE="17 3 * * *"
BACKUP_LOCAL_RETENTION_DAYS=14
BACKUP_LOCAL_RETENTION_COUNT=30
BACKUP_SKIP_UNCHANGED=true
BACKUP_CRITICAL_PATHS=.env,docker-compose.yml,prisma,data/shopify,ops
BACKUP_ENCRYPTION_PASSPHRASE=replace-with-a-long-backup-passphrase
BACKUP_GITHUB_ENABLED=true
BACKUP_GITHUB_TOKEN=
BACKUP_GITHUB_REPOSITORY=Marks013/nerdlingolab-Backup
BACKUP_GITHUB_RELEASE_TAG=nerdlingolab-backups
BACKUP_GITHUB_RETENTION_COUNT=30
BACKUP_ALERT_EMAIL_ENABLED=false
BACKUP_ALERT_EMAIL_TO=
