generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPERADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  REFUNDED
  CHARGEBACK
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
  RETURNED
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum LoyaltyTier {
  GENIN
  CHUNIN
  JONIN
  HOKAGE
}

enum LoyaltyLedgerType {
  EARN
  REDEEM
  ADJUST
  EXPIRE
  REFUND_REVERSAL
}

enum ReferralStatus {
  PENDING
  REWARDED
  CANCELED
}

enum InventoryLedgerType {
  INITIAL
  SALE
  RETURN
  ADJUSTMENT
  RESERVATION
  RELEASE
}

enum WebhookProvider {
  MERCADO_PAGO
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum ShippingProvider {
  MANUAL
  MERCADO_ENVIOS
  MELHOR_ENVIO
}

enum ShipmentStatus {
  PENDING
  HANDLING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  DELAYED
  UNKNOWN
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  role              UserRole  @default(CUSTOMER)
  cpf               String?   @unique
  phone             String?
  birthday          DateTime?
  adminNotes        String?   @db.Text
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  orders            Order[]
  couponRedemptions CouponRedemption[]
  loyaltyPoints     LoyaltyPoints?
  loyaltyLedger     LoyaltyLedger[]
  addresses         CustomerAddress[]
  supportTickets    SupportTicket[]
  supportReplies    SupportTicketReply[]
  assignedCoupons   Coupon[]             @relation("AssignedCoupons")
  mediaAssets       MediaAsset[]
  referralCode      ReferralCode?
  referralsSent     Referral[]           @relation("ReferralInviter")
  referralReceived  Referral?            @relation("ReferralInvitee")

  @@index([role])
  @@index([createdAt])
}

model SupportTicket {
  id                  String              @id @default(cuid())
  ticketId            String              @unique
  userId              String?
  name                String
  email               String
  phone               String?
  subject             String
  subjectLabel        String
  message             String              @db.Text
  status              SupportTicketStatus @default(OPEN)
  resendId            String?
  emailDeliveryStatus String              @default("PENDING")
  emailProviderError  String?
  rating              Int?
  ratingComment       String?
  ratedAt             DateTime?
  reopenReason        String?
  reopenedAt          DateTime?
  reopenCount         Int                 @default(0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user    User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  replies SupportTicketReply[]

  @@index([status, createdAt])
  @@index([rating, ratedAt])
  @@index([userId, createdAt])
}

model SupportTicketReply {
  id                String   @id @default(cuid())
  ticketId          String
  adminUserId       String?
  message           String   @db.Text
  deliveryStatus    String   @default("PENDING")
  providerMessageId String?
  providerError     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  adminUser User?         @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([adminUserId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model CustomerAddress {
  id         String   @id @default(cuid())
  userId     String
  label      String?
  recipient  String
  postalCode String
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  country    String   @default("BR")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
}

model Category {
  id          String   @id @default(cuid())
  parentId    String?
  name        String
  slug        String   @unique
  description String?
  imageUrl    String?
  position    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
  @@index([isActive, position])
}

model Product {
  id                  String        @id @default(cuid())
  categoryId          String?
  title               String
  slug                String        @unique
  description         String        @db.Text
  shortDescription    String?
  status              ProductStatus @default(DRAFT)
  brand               String?
  tags                String[]      @default([])
  images              Json          @default("[]")
  metafields          Json          @default("{}")
  priceCents          Int
  compareAtPriceCents Int?
  seoTitle            String?
  seoDescription      String?
  publishedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  category        Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variants        ProductVariant[]
  orderItems      OrderItem[]
  inventoryLedger InventoryLedger[]
  mediaUsages     MediaAssetUsage[]

  @@index([status, publishedAt])
  @@index([categoryId])
}

model ProductVariant {
  id                  String   @id @default(cuid())
  productId           String
  title               String
  sku                 String   @unique
  barcode             String?
  optionValues        Json     @default("{}")
  priceCents          Int
  compareAtPriceCents Int?
  stockQuantity       Int      @default(0)
  reservedQuantity    Int      @default(0)
  weightGrams         Int?
  heightCm            Int?
  widthCm             Int?
  lengthCm            Int?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  product         Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]
  inventoryLedger InventoryLedger[]

  @@index([productId, isActive])
}

model ProductShippingPreset {
  id          String   @id @default(cuid())
  name        String   @unique
  weightGrams Int
  heightCm    Int
  widthCm     Int
  lengthCm    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([weightGrams])
}

model ManualShippingRate {
  id                    String   @id @default(cuid())
  name                  String
  description           String?
  priceCents            Int
  estimatedBusinessDays Int      @default(5)
  minSubtotalCents      Int?
  maxSubtotalCents      Int?
  minItems              Int?
  maxItems              Int?
  postalCodePrefixes    String[] @default([])
  sortOrder             Int      @default(0)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model StorefrontTheme {
  id                            String   @id @default(cuid())
  singletonKey                  String   @unique @default("default")
  name                          String   @default("Tema principal")
  announcementText              String   @default("FRETE GRÁTIS em compras acima de R$99,90")
  freeShippingThresholdCents    Int      @default(9990)
  maxInstallments               Int      @default(12)
  cardInstallmentMonthlyRateBps Int      @default(0)
  pixDiscountBps                Int      @default(1000)
  paymentFeeSource              String   @default("MANUAL")
  supportEmail                  String   @default("nerdlingolab@gmail.com")
  whatsappLabel                 String   @default("(44) 99136-2488")
  instagramUrl                  String   @default("https://instagram.com/nerdlingolab")
  footerNotice                  String   @default("Oferta exclusiva neste site oficial, sujeita a variação. Evite comprar produtos mais baratos ou de outras lojas, para evitar golpes.")
  newsletterTitle               String   @default("Receba nossas promoções")
  newsletterDescription         String   @default("Inscreva-se para receber descontos exclusivos direto no seu e-mail!")
  heroSlides                    Json     @default("[]")
  promoSlides                   Json     @default("[]")
  updatedAt                     DateTime @updatedAt
  createdAt                     DateTime @default(now())
}

model MediaAsset {
  id          String    @id @default(cuid())
  bucket      String
  objectKey   String    @unique
  url         String
  originalUrl String?
  fileName    String
  mimeType    String
  sizeBytes   Int
  width       Int?
  height      Int?
  source      String    @default("UPLOAD")
  altText     String?
  createdById String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  usages    MediaAssetUsage[]

  @@index([source, createdAt])
  @@index([deletedAt])
}

model MediaAssetUsage {
  id        String   @id @default(cuid())
  assetId   String
  productId String?
  ownerType String
  ownerId   String
  fieldName String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  asset   MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  product Product?   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([assetId, ownerType, ownerId, fieldName, sortOrder])
  @@index([ownerType, ownerId])
  @@index([productId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("footer")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, createdAt])
}

model MarketingPopup {
  id             String    @id @default(cuid())
  title          String
  description    String
  eyebrow        String?
  ctaLabel       String?
  ctaHref        String?
  imageUrl       String?
  placement      String    @default("GLOBAL")
  audience       String    @default("ALL")
  triggerType    String    @default("DELAY")
  triggerValue   Int       @default(1200)
  frequencyHours Int       @default(24)
  themeTone      String    @default("ORANGE")
  priority       Int       @default(0)
  isActive       Boolean   @default(false)
  startsAt       DateTime?
  endsAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([isActive, placement, priority])
  @@index([startsAt, endsAt])
}

model NotificationTemplate {
  id            String   @id @default(cuid())
  templateKey   String   @unique
  name          String
  channel       String   @default("EMAIL")
  subject       String
  previewText   String?
  body          String
  ctaLabel      String?
  ctaHref       String?
  isActive      Boolean  @default(true)
  cooldownHours Int      @default(24)
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InventoryLedger {
  id             String              @id @default(cuid())
  productId      String
  variantId      String?
  orderId        String?
  type           InventoryLedgerType
  quantityDelta  Int
  quantityAfter  Int
  reason         String
  idempotencyKey String?             @unique
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now())

  product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)
  order   Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([variantId, createdAt])
}

model Order {
  id                            String            @id @default(cuid())
  orderNumber                   String            @unique
  userId                        String?
  couponId                      String?
  email                         String
  status                        OrderStatus       @default(PENDING_PAYMENT)
  paymentStatus                 PaymentStatus     @default(PENDING)
  fulfillmentStatus             FulfillmentStatus @default(UNFULFILLED)
  currency                      String            @default("BRL")
  subtotalCents                 Int
  discountCents                 Int               @default(0)
  loyaltyDiscountCents          Int               @default(0)
  shippingCents                 Int               @default(0)
  shippingOptionId              String?
  shippingServiceName           String?
  shippingProvider              ShippingProvider?
  shippingPostalCode            String?
  shippingEstimatedBusinessDays Int?
  taxCents                      Int               @default(0)
  totalCents                    Int
  loyaltyPointsRedeemed         Int               @default(0)
  loyaltyPointsEarned           Int               @default(0)
  mercadoPagoPreferenceId       String?
  mercadoPagoPaymentId          String?           @unique
  mercadoPagoStatus             String?
  paymentIdempotencyKey         String?           @unique
  shippingAddress               Json
  billingAddress                Json?
  customerSnapshot              Json              @default("{}")
  paidAt                        DateTime?
  canceledAt                    DateTime?
  createdAt                     DateTime          @default(now())
  updatedAt                     DateTime          @updatedAt

  user               User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  coupon             Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  couponRedemptions  CouponRedemption[]
  loyaltyLedger      LoyaltyLedger[]
  inventoryLedger    InventoryLedger[]
  shipments          Shipment[]
  referralsQualified Referral[]

  @@index([userId, createdAt])
  @@index([paymentStatus, status])
  @@index([mercadoPagoPreferenceId])
}

model Shipment {
  id                  String           @id @default(cuid())
  orderId             String
  provider            ShippingProvider @default(MANUAL)
  externalShipmentId  String?
  carrierName         String?
  carrierUrl          String?
  trackingNumber      String?
  status              ShipmentStatus   @default(PENDING)
  substatus           String?
  estimatedDeliveryAt DateTime?
  shippedAt           DateTime?
  deliveredAt         DateTime?
  lastSyncedAt        DateTime?
  rawPayload          Json             @default("{}")
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  order  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events ShipmentEvent[]

  @@unique([provider, externalShipmentId])
  @@index([orderId, createdAt])
  @@index([status])
}

model ShipmentEvent {
  id          String         @id @default(cuid())
  shipmentId  String
  status      ShipmentStatus @default(UNKNOWN)
  substatus   String?
  description String?
  occurredAt  DateTime
  rawPayload  Json           @default("{}")
  createdAt   DateTime       @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, occurredAt])
}

model OrderItem {
  id                      String   @id @default(cuid())
  orderId                 String
  productId               String
  variantId               String?
  productTitle            String
  variantTitle            String?
  sku                     String?
  quantity                Int
  unitPriceCents          Int
  compareAtUnitPriceCents Int?
  discountCents           Int      @default(0)
  totalCents              Int
  productSnapshot         Json     @default("{}")
  createdAt               DateTime @default(now())

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Coupon {
  id               String     @id @default(cuid())
  code             String     @unique
  type             CouponType
  value            Int
  minSubtotalCents Int?
  maxDiscountCents Int?
  usageLimit       Int?
  usedCount        Int        @default(0)
  perCustomerLimit Int?
  assignedUserId   String?
  startsAt         DateTime?
  expiresAt        DateTime?
  isActive         Boolean    @default(true)
  isPublic         Boolean    @default(true)
  createdByUserId  String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  orders       Order[]
  redemptions  CouponRedemption[]
  assignedUser User?              @relation("AssignedCoupons", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([code, isActive])
  @@index([isActive, isPublic])
  @@index([assignedUserId])
  @@index([startsAt, expiresAt])
}

model LoyaltyProgramSettings {
  id                         String   @id @default(cuid())
  singletonKey               String   @unique @default("default")
  programName                String   @default("Nerdcoins")
  isEnabled                  Boolean  @default(true)
  pointsPerReal              Int      @default(5)
  signupBonusPoints          Int      @default(50)
  birthdayBonusPoints        Int      @default(100)
  referralInviterBonusPoints Int      @default(150)
  referralInviteeBonusPoints Int      @default(50)
  referralMinOrderCents      Int      @default(0)
  redeemCentsPerPoint        Int      @default(1)
  minRedeemPoints            Int      @default(100)
  maxRedeemPoints            Int?
  couponExpiresInDays        Int      @default(30)
  pointsExpireInDays         Int?
  showPendingPoints          Boolean  @default(true)
  requireAccountToRedeem     Boolean  @default(true)
  chuninOrderThreshold       Int      @default(3)
  joninOrderThreshold        Int      @default(10)
  hokageOrderThreshold       Int      @default(20)
  chuninSpendThresholdCents  Int      @default(30000)
  joninSpendThresholdCents   Int      @default(100000)
  hokageSpendThresholdCents  Int      @default(200000)
  chuninMultiplier           Int      @default(120)
  joninMultiplier            Int      @default(150)
  hokageMultiplier           Int      @default(200)
  updatedAt                  DateTime @updatedAt
  createdAt                  DateTime @default(now())
}

model CouponRedemption {
  id             String   @id @default(cuid())
  couponId       String
  userId         String?
  orderId        String
  discountCents  Int
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId, createdAt])
  @@index([userId, couponId])
}

model LoyaltyPoints {
  id               String      @id @default(cuid())
  userId           String      @unique
  balance          Int         @default(0)
  lifetimeEarned   Int         @default(0)
  lifetimeRedeemed Int         @default(0)
  lifetimeExpired  Int         @default(0)
  tier             LoyaltyTier @default(GENIN)
  tierOrderCount   Int         @default(0)
  tierSpendCents   Int         @default(0)
  tierUpdatedAt    DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoyaltyLedger {
  id             String            @id @default(cuid())
  userId         String
  orderId        String?
  type           LoyaltyLedgerType
  pointsDelta    Int
  balanceAfter   Int
  tierBefore     LoyaltyTier?
  tierAfter      LoyaltyTier?
  reason         String
  customerNote   String?
  expiresAt      DateTime?
  sourceLedgerId String?
  idempotencyKey String            @unique
  metadata       Json              @default("{}")
  createdAt      DateTime          @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([sourceLedgerId])
  @@index([type])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code, isActive])
}

model Referral {
  id                  String         @id @default(cuid())
  inviterId           String
  inviteeId           String         @unique
  referralCode        String
  status              ReferralStatus @default(PENDING)
  qualifyingOrderId   String?
  inviterRewardPoints Int            @default(0)
  inviteeRewardPoints Int            @default(0)
  rewardedAt          DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  inviter         User   @relation("ReferralInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee         User   @relation("ReferralInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)
  qualifyingOrder Order? @relation(fields: [qualifyingOrderId], references: [id], onDelete: SetNull)

  @@index([inviterId, status])
  @@index([referralCode])
  @@index([qualifyingOrderId])
}

model WebhookEvent {
  id              String          @id @default(cuid())
  provider        WebhookProvider
  externalEventId String
  status          WebhookStatus   @default(RECEIVED)
  payload         Json
  processedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([provider, externalEventId])
  @@index([provider, status])
}
